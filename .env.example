# App
PORT=3000
NODE_ENV=development

# Base de datos
# Opción A — Railway inyecta esto automáticamente al conectar un plugin PostgreSQL
DATABASE_URL=

# Opción B — variables individuales para desarrollo local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amparar
DB_USER=postgres
DB_PASS=postgres

# JWT — usar secretos fuertes en producción
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Intersoftic API (pendiente de documentación)
INTERSOFTIC_API_URL=
INTERSOFTIC_API_KEY=

# Sincronización — cron expression (default: cada hora)
SYNC_CRON_INTERVAL=0 * * * *
